*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#050816,#0b132b,#1c2541);
    color:white;
    overflow:hidden;
}

.container{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:30px;
}

.title{
    font-size:70px;
    letter-spacing:4px;
    margin-bottom:20px;
    animation:fade 2s;
}

#typing{
    color:#7fffd4;
    margin-bottom:40px;
    min-height:35px;
}

.message{
    max-width:800px;
}

.message p{
    font-size:22px;
    line-height:40px;
    margin:20px 0;
    opacity:0;
    animation:show 1s forwards;
}

.message p:nth-child(1){animation-delay:1s;}
.message p:nth-child(2){animation-delay:3s;}
.message p:nth-child(3){animation-delay:5s;}
.message p:nth-child(4){animation-delay:7s;}
.message p:nth-child(5){animation-delay:9s;}
.message p:nth-child(6){animation-delay:11s;}

.last span{
    font-size:40px;
    color:#00ffd5;
}

.stars{
    position:fixed;
    width:100%;
    height:100%;
    background:
    radial-gradient(white 1px,transparent 1px);
    background-size:40px 40px;
    animation:move 80s linear infinite;
    opacity:.3;
}

@keyframes move{
    from{background-position:0 0;}
    to{background-position:0 1000px;}
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(40px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@keyframes show{
    to{
        opacity:1;
    }
}