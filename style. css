*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
    background:linear-gradient(135deg,#0f172a,#1e293b,#020617);
    overflow:hidden;
    color:#fff;
}

.container{
    text-align:center;
    max-width:900px;
    padding:40px;
    z-index:2;
}

h1{
    font-size:4rem;
    margin-bottom:20px;
    color:#ffffff;
    text-shadow:0 0 20px rgba(255,255,255,0.4);
}

#typing{
    font-size:1.6rem;
    color:#38bdf8;
    margin-bottom:35px;
    min-height:40px;
}

p{
    font-size:1.25rem;
    line-height:1.8;
    margin:18px 0;
    opacity:0;
    animation:fadeUp 1s forwards;
}

p:nth-child(3){animation-delay:1s;}
p:nth-child(4){animation-delay:2.5s;}
p:nth-child(5){animation-delay:4s;}
p:nth-child(6){animation-delay:5.5s;}
p:nth-child(7){animation-delay:7s;}

.last{
    margin-top:35px;
    font-size:2rem;
    color:#7dd3fc;
    font-weight:bold;
}

.stars{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background-image:
        radial-gradient(white 1px, transparent 1px);
    background-size:50px 50px;
    opacity:.25;
    animation:moveStars 70s linear infinite;
    z-index:0;
}

@keyframes fadeUp{
    from{
        opacity:0;
        transform:translateY(30px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

@keyframes moveStars{
    from{
        background-position:0 0;
    }
    to{
        background-position:0 1000px;
    }
}

@media (max-width:768px){

.container{
    padding:25px;
}

h1{
    font-size:2.8rem;
}

#typing{
    font-size:1.2rem;
}

p{
    font-size:1rem;
}

.last{
    font-size:1.5rem;
}

}